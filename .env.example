# Upstash Redis — free tier at https://upstash.com
# Used for caching stock price lookups and RRG accumulated closes
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cron job secret — secures the /api/cron/rrg endpoint
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# Upstash QStash — schedule daily RRG data accumulation at 17:00 WIB (10:00 UTC)
QSTASH_URL=
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=